# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
APP_URL="http://localhost:3000"

# DATABASE_URL: PostgreSQL connection string (Use 'db' for Docker)
DATABASE_URL="postgresql://user:password@db:5432/audiostream?schema=public"

# REDIS_URL: Redis connection string for BullMQ (Use 'redis' for Docker)
REDIS_URL="redis://redis:6379"

# JWT_SECRET: Secret key for signing JSON Web Tokens
JWT_SECRET="super-secret-jwt-key-change-in-production"

# AWS / S3 Compatible Storage (MinIO)
AWS_ACCESS_KEY_ID="minioadmin"
AWS_SECRET_ACCESS_KEY="minioadmin"
AWS_REGION="us-east-1"
AWS_S3_BUCKET="audiostream-bucket"
AWS_S3_ENDPOINT="http://minio:9000"
